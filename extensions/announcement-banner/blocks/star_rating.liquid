{% assign announcement = shop.metafields.my_app.announcement %}

{% if announcement.value != blank %}
  <div style="
    background-color: #ff6900;
    color: #ffffff;
    text-align: center;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: bold;
    width: 100%;
  ">
    {{ announcement.value }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Banner",
  "target": "head",
  "settings": []
}
{% endschema %}